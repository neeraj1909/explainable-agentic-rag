APP_NAME=explainable-agentic-rag
ENVIRONMENT=development
LOG_LEVEL=INFO

# LiteLLM proxy/OpenAI-compatible mode. Keep key/base blank in this template.
# For the LAN LiteLLM subscription proxy, chatgpt/* models require streaming.
LITELLM_MODEL=chatgpt/gpt-5.5
LITELLM_CUSTOM_LLM_PROVIDER=openai
LITELLM_API_KEY=
LITELLM_API_BASE=
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
LITELLM_TEMPERATURE=0.2
LITELLM_TIMEOUT_SECONDS=30
LITELLM_MAX_TOKENS=25600
LITELLM_STREAMING=true

OPENAI_EMBEDDING_MODEL=
OPENAI_API_KEY=

PHOENIX_PROJECT_NAME=explainable-agentic-rag
PHOENIX_COLLECTOR_ENDPOINT=http://10.20.30.1:16006/v1/traces
